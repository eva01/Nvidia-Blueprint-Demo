# ============================================================================
# NEMOTRON VOICE AGENT - CLOUD NIM SCHOOL FACILITY DEMO
# ============================================================================
# Copy this file to the ignored root .env for the browser-microphone demo.
# Put the real NVIDIA API key only in your local .env or shell environment.
# Do not paste real NVIDIA API keys into committed example files.

# Keep this blank in committed files. The ignored root .env may contain the real key.
NVIDIA_API_KEY=

IMAGE_VERSION=1.0.0
TRANSPORT=WEBRTC
WORKERS=1

PROMPT_FILE_PATH=./config/prompt.yaml
SYSTEM_PROMPT_SELECTOR=nemotron-3-nano/school_facility_support
FACILITY_TICKETS_DB_PATH=./data/facility_tickets.db
ENABLE_FACILITY_TICKET_AUTOCREATE=true
SOVEREIGN_MODE=local-demo
DATA_RESIDENCY_REGION=local-dev
ALLOW_CLOUD_NIM=true
PII_REDACTION_ENABLED=false
AUDIT_LOG_ENABLED=true

# School knowledge retrieval.
# Default fuzzy mode needs no extra API calls. sqlite-vec and faiss modes embed configured KB chunks
# with a hosted NVIDIA endpoint and store vectors locally.
ENABLE_SCHOOL_KNOWLEDGE_RAG=true
SCHOOL_KNOWLEDGE_BASE_PATH=./config/school_knowledge_base.yaml
SCHOOL_KNOWLEDGE_BACKEND=fuzzy
SCHOOL_VECTOR_DB_PATH=./data/school_knowledge_vectors.db
SCHOOL_FAISS_INDEX_PATH=./data/school_knowledge.faiss
NVIDIA_EMBED_URL=https://integrate.api.nvidia.com/v1
NVIDIA_EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2
ENABLE_NVIDIA_RERANK=false
NVIDIA_RERANK_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/reranking
NVIDIA_RERANK_MODEL=nvidia/llama-nemotron-rerank-vl-1b-v2
NVIDIA_RAG_TIMEOUT_SECONDS=30

# Optional NVIDIA Nemotron Safety Guard output filtering before TTS.
ENABLE_NVIDIA_SAFETY_GUARD=false
NVIDIA_SAFETY_URL=https://integrate.api.nvidia.com/v1
NVIDIA_SAFETY_MODEL=nvidia/llama-3.1-nemotron-safety-guard-8b-v3
NVIDIA_SAFETY_TIMEOUT_SECONDS=30
NVIDIA_SAFETY_FALLBACK_TEXT=I cannot help with that request. Please ask about school facility support.

# Future ingestion note: Nemotron Parse is not wired into this runtime yet.
# Use it later for scanned PDFs, tables, forms, and multimodal school documents.

# Disable speculative speech for deliberate form-filling demos.
# When false, the LLM waits for final ASR transcripts instead of stable interim text.
ENABLE_SPECULATIVE_SPEECH=false
VAD_PROFILE=ASR
CHAT_HISTORY_LIMIT=12
AUDIO_OUT_10MS_CHUNKS=5
ENABLE_ASR_AUDIO_DUMP=false
ENABLE_TTS_AUDIO_DUMP=false
AUDIO_DUMP_PATH=./audio_dumps
TTS_IPA_FILE_PATH=./config/ipa.json

ASR_SERVER_URL=grpc.nvcf.nvidia.com:443
ASR_CLOUD_FUNCTION_ID=1598d209-5e27-4d3c-8079-4751568b1081
ASR_MODEL_NAME=parakeet-1.1b-en-US-asr-streaming-silero-vad-sortformer
# Higher values wait longer before ASR marks an answer final.
ASR_STOP_HISTORY=900
ASR_STOP_HISTORY_EOU=900

TTS_SERVER_URL=grpc.nvcf.nvidia.com:443
TTS_VOICE_ID=Magpie-Multilingual.EN-US.Aria
TTS_MODEL_NAME=magpie_tts_ensemble-Magpie-Multilingual
TTS_LANGUAGE=en-US
ENABLE_TTS_TEXT_FILTER=true

NVIDIA_LLM_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=nvidia/nemotron-3-nano-30b-a3b
TEMPERATURE=0.2
TOP_P=1.0
ENABLE_THINKING=false
MAX_TOKENS=512
